# JWT must match the secret used by JwtAuthGuard in feature modules (or set JWT_SECRET everywhere).
JWT_SECRET=your-secret-key

# Public URL of the Vite app (OAuth redirect after sign-in)
FRONTEND_URL=http://localhost:5173

# Express session (OAuth state); falls back to JWT_SECRET if unset
SESSION_SECRET=

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Without these, "Sign in with Google" would open Google with an invalid URL (404).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# GitHub OAuth — create at https://github.com/settings/developers
# Authorization callback URL must match exactly (e.g. http://localhost:3000/auth/github/callback).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback
EMAIL_TEST_RECIPIENT=your-verified-email@example.com
